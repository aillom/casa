{
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/secrets/**)",
      "Edit(.github/workflows/**)",
      "Write(.github/workflows/**)",
      "Edit(.casa/kernel/policies/**)",
      "Write(.casa/kernel/policies/**)",
      "Edit(.casa/kernel/risk-model/**)",
      "Write(.casa/kernel/risk-model/**)",
      "Edit(.casa/registry/stacks.json)",
      "Write(.casa/registry/stacks.json)",
      "Edit(.casa/registry/recipes.json)",
      "Write(.casa/registry/recipes.json)",
      "Edit(.casa/registry/skill-marketplace.json)",
      "Write(.casa/registry/skill-marketplace.json)",
      "Edit(.casa/registry/skills.lock.json)",
      "Write(.casa/registry/skills.lock.json)",
      "Edit(devops/**)",
      "Write(devops/**)",
      "Edit(**/migrations/**)",
      "Write(**/migrations/**)",
      "Edit(**/auth/**)",
      "Write(**/auth/**)",
      "Edit(**/security/**)",
      "Write(**/security/**)",
      "Edit(**/contracts/openapi/**)",
      "Write(**/contracts/openapi/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .casa/governance/hooks/protected-path-guard.mjs"
          }
        ]
      }
    ]
  }
}
